# Belt-and-braces: vercel.json sets outputDirectory: "public", so only files
# under public/ are served. This file additionally trims the upload so source
# and dev artefacts cannot leak through any future misconfiguration.
#
# Do NOT ignore package.json, package-lock.json, or scripts/ — Vercel needs
# them at the build root to install deps and run scripts/write-config.js.

# Source / dev (not needed at build time, must never ship)
README.md
docs/
supabase/
apply_*.py
config.example.js

# Env (Vercel injects vars from project settings)
.env
.env.local
.env.production
.env.*.local
.env.example

# VCS / IDE
.github/

# Plans / claude artefacts
.claude/

# OS
.DS_Store
Thumbs.db

# One-shot helper scripts at repo root
test-*.mjs
